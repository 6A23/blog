<view class="container">
  <view class="header">
    <view class="title">建设中...</view>
    <view class="subtitle">正在建设：{{roomName}}</view>
  </view>

  <!-- 阶段 & 机器人 -->
  <view class="meta-row">
    <view class="meta-tag">📍 {{stage}}</view>
    <view class="meta-tag">🤖 {{robot}}</view>
  </view>

  <view class="card">
    <view class="section-title">建设进度</view>
    <view class="progress-container">
      <view class="progress-bar" style="width: {{progress}}%"></view>
    </view>
    <view class="progress-text">{{progress}}%</view>
    <view class="report-hint {{progress >= 100 ? 'done' : ''}}">{{reportStatus}}</view>
  </view>

  <view class="card">
    <view class="section-title">建设日志</view>
    <view class="log-list">
      <view class="log-item" wx:for="{{logs}}" wx:key="index">
        <text class="log-time">{{item.time}}</text>
        <text class="log-msg">{{item.msg}}</text>
      </view>
    </view>
  </view>

  <view class="action-area">
    <button class="btn-secondary" bindtap="goBack">返回</button>
  </view>
</view>
