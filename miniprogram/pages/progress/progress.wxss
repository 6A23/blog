.progress-container {
  height: 40rpx;
  background-color: #002244;
  border-radius: 20rpx;
  overflow: hidden;
  margin: 30rpx 0;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #6a5acd, #C0C0C0);
  transition: width 0.5s;
}

.meta-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.meta-tag {
  background: #002244;
  color: #6af;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #6af;
}

.report-hint {
  font-size: 24rpx;
  color: #888;
  margin-top: 12rpx;
  text-align: center;
  min-height: 36rpx;
}

.report-hint.done {
  color: #00ff88;
}

.progress-text {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
}

.time-card {
  background-color: #002244;
  padding: 40rpx;
  border-radius: 12rpx;
  text-align: center;
}

.time-value {
  font-size: 60rpx;
  font-weight: bold;
  color: #C0C0C0;
}

.time-label {
  font-size: 24rpx;
  color: #888;
  margin-top: 10rpx;
}

.log-list {
  display: flex;
  flex-direction: column;
}

.log-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #002244;
}

.log-item:last-child {
  border-bottom: none;
}

.log-time {
  color: #888;
  width: 120rpx;
  font-size: 24rpx;
}

.log-msg {
  color: #C0C0C0;
  font-size: 28rpx;
}