.room-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.room-item {
  flex: 1 1 calc(33.33% - 20rpx);
  background-color: #002244;
  border-radius: 12rpx;
  padding: 30rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.room-item.active {
  background-color: #C0C0C0;
  color: #001F3F;
  transform: scale(1.05);
}

.room-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.room-name {
  font-size: 28rpx;
}

.custom-input {
  background-color: #002244;
  color: #C0C0C0;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.placeholder {
  color: #888;
}

.action-area {
  margin-top: 60rpx;
}